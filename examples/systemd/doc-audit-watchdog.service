[Unit]
Description=Doc Audit health watchdog
After=doc-audit.service
# Note: NO PartOf=doc-audit.service. The watchdog must outlive doc-audit's
# restart cycle — otherwise systemd would SIGTERM the watchdog mid-restart.

[Service]
Type=oneshot
WorkingDirectory=%h/workspace/audit-bot
Environment=PATH=%h/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
EnvironmentFile=-%h/workspace/audit-bot/.state/env
ExecStart=%h/workspace/audit-bot/bin/watchdog.sh
